  padding: 14px;
  border: 1px dashed #c8d3ce;
  border-radius: 8px;
  color: var(--muted);
  background: rgba(255, 255, 255, 0.7);
  line-height: 1.45;
}

.saved-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}

.saved-header p {
  margin: 4px 0 0;
  color: var(--muted);
  font-size: 13px;
}

.toast {
  position: fixed;
  right: 16px;
  bottom: 16px;
  left: 16px;
  transform: translateY(120px);
  max-width: 448px;
  margin: 0 auto;
  padding: 13px 14px;
  border-radius: 8px;
  background: #111d18;
  color: #fff;
  font-weight: 800;
  text-align: center;
  transition: transform 180ms ease;
}

.toast.is-visible {
  transform: translateY(0);
}

@media (min-width: 700px) {
  .app-shell {
    padding-top: 34px;
  }

  .top-bar {
    padding-top: 14px;
  }
}
