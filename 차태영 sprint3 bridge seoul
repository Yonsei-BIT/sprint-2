#!/usr/bin/env python3
import json
import os
import urllib.parse
import urllib.request
from http.server import SimpleHTTPRequestHandler, ThreadingHTTPServer


PORT = int(os.getenv("PORT", "8787"))
HOST = os.getenv("HOST", "127.0.0.1")
CLIENT_ID = os.getenv("NAVER_SEARCH_CLIENT_ID", "")
CLIENT_SECRET = os.getenv("NAVER_SEARCH_CLIENT_SECRET", "")


class BridgeHandler(SimpleHTTPRequestHandler):
    def end_headers(self):
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.send_header("Cache-Control", "no-store, max-age=0")
        super().end_headers()

    def end_json(self, status, payload):
        body = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_OPTIONS(self):
        self.send_response(204)
        self.end_headers()

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)

        if parsed.path == "/health":
            self.end_json(200, {"status": "ok"})
            return

        if parsed.path != "/api/naver/local":
            return super().do_GET()

        if not CLIENT_ID or not CLIENT_SECRET:
            self.end_json(
                500,
                {
                    "error": "missing_naver_credentials",
                    "message": "Set NAVER_SEARCH_CLIENT_ID and NAVER_SEARCH_CLIENT_SECRET.",
                },
            )
            return

        params = urllib.parse.parse_qs(parsed.query)
        query = params.get("query", [""])[0].strip()
        display = params.get("display", ["5"])[0]

        if not query:
            self.end_json(400, {"error": "missing_query"})
            return

        api_query = urllib.parse.urlencode({"query": query, "display": display, "sort": "comment"})
        request = urllib.request.Request(
            f"https://openapi.naver.com/v1/search/local.json?{api_query}",
            headers={
                "X-Naver-Client-Id": CLIENT_ID,
                "X-Naver-Client-Secret": CLIENT_SECRET,
            },
        )

        try:
            with urllib.request.urlopen(request, timeout=6) as response:
                raw = response.read().decode("utf-8")
                data = json.loads(raw)
        except urllib.error.HTTPError as exc:
            detail = exc.read().decode("utf-8", errors="replace")
            self.end_json(exc.code, {"error": "naver_api_error", "detail": detail})
            return
        except Exception as exc:
            self.end_json(502, {"error": "naver_request_failed", "detail": str(exc)})
            return

        self.end_json(200, data)


if __name__ == "__main__":
    server = ThreadingHTTPServer((HOST, PORT), BridgeHandler)
    print(f"Bridge Seoul running at http://{HOST}:{PORT}")
    server.serve_forever()

