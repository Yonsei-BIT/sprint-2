]);

function correctQuery(query) {
  const corrections = [];
  const corrected = normalize(query)
    .split(" ")
    .map((token) => {
      const correction = spellingCorrections.get(token);
      if (correction && correction !== token) {
        corrections.push(`${token} → ${correction}`);
        return correction;
      }
      return token;
    })
    .join(" ");

  return {
    query: corrected || query,
    corrections,
  };
}

function matchingTerms(source, termList) {
  return termList.filter((item) => source.includes(item.test)).flatMap((item) => item.terms);
}

function unique(values) {
  return Array.from(new Set(values.filter(Boolean)));
}

function parseSearchIntent(query) {
  const correction = correctQuery(query);
  const normalized = correction.query;
  const areas = unique(matchingTerms(normalized, areaTerms));
  const categories = unique(matchingTerms(normalized, categoryTerms));
  const specificCategories = categories.filter((term) => !["맛집", "식당"].includes(term));
  const genericCategories = categories.filter((term) => ["맛집", "식당"].includes(term));

  return {
    originalQuery: query,
    correctedQuery: normalized,
    corrections: correction.corrections,
    areas,
    specificCategories,
    genericCategories,
  };
}

function buildSearchQueries(intent, limit = 10) {
  const queries = [];
  const areas = intent.areas.length ? intent.areas : [""];
  const categories = intent.specificCategories.length
    ? intent.specificCategories
    : intent.genericCategories.length
      ? intent.genericCategories
      : [];

  areas.forEach((area) => {
    categories.forEach((category) => {
      queries.push(`${area} ${category}`.trim());
    });
  });

  if (!intent.specificCategories.length && intent.areas.length) {
    intent.areas.forEach((area) => queries.push(`${area} 맛집`));
  }

  queries.push(intent.correctedQuery);

  if (intent.specificCategories.length && intent.areas.length) {
    intent.areas.forEach((area) => queries.push(`${area} 맛집`));
  }

  return unique(queries).slice(0, limit);
}

function expandQuery(query) {
  const intent = parseSearchIntent(query);
  const normalized = intent.correctedQuery;
  const expansions = new Set([normalized, ...buildSearchQueries(intent)]);

  synonymMap.forEach((values, key) => {
    if (normalized.includes(key)) {
      values.forEach((value) => expansions.add(normalized.replace(key, value)));
      values.forEach((value) => expansions.add(value));
    }
  });

  intent.areas.forEach((area) => {
    const categories = intent.specificCategories.length ? intent.specificCategories : intent.genericCategories;
    categories.forEach((category) => {
      expansions.add(`${area} ${category}`);
    });
  });

  return Array.from(expansions).filter(Boolean);
}

function scorePlace(place, query) {
  const normalized = normalize(query);
  const expanded = expandQuery(query);
  const searchable = [
    place.englishName,
    place.koreanName,
    place.category,
    place.area,
    ...place.keywords,
  ]
    .map(normalize)
    .join(" ");

  let score = 0;

  if (searchable.includes(normalized)) score += 80;
  expanded.forEach((term) => {
    if (searchable.includes(term)) score += 32;
  });

  normalized.split(" ").forEach((token) => {
    if (token.length > 1 && searchable.includes(token)) score += 12;
  });

  if (score > 0) {
    score += Math.min(place.reviews / 500, 18);
    if (place.rating) score += place.rating * 2;
    if (place.waitlistGrade === "A") score += 4;
    if (place.waitlistGrade === "B") score += 2;
  }

  return score;
}

function searchPlaces(query, limit = 3) {
  return places
    .map((place) => ({ place, score: scorePlace(place, query) }))
    .filter((item) => item.score > 0)
    .sort((a, b) => b.score - a.score)
    .slice(0, limit)
    .map((item) => item.place);
}

function shouldPreferKnownTransitPlace(query) {
  const normalized = normalize(query);
  return ["station", "exit", "airport", "terminal", "역", "출구", "공항", "터미널"].some((term) =>
    normalized.includes(term)
  );
}

function stripHtml(value) {
  const template = document.createElement("template");
  template.innerHTML = value || "";
  return template.content.textContent || "";
}

function mapNaverItem(item, index) {
  const title = stripHtml(item.title);
  const category = stripHtml(item.category || "Place");
  const roadAddress = stripHtml(item.roadAddress || item.address || "");
  const lat = item.mapy ? Number(item.mapy) / 10000000 : null;
  const lng = item.mapx ? Number(item.mapx) / 10000000 : null;

  return {
    id: `naver-${item.mapx || "x"}-${item.mapy || "y"}-${index}`,
    englishName: title,
    koreanName: title,
    category,
    area: roadAddress || "Naver local result",
    lat,
    lng,
    reviews: 0,
    rating: null,
    waitlistGrade: "Unknown",
    keywords: [title, roadAddress, category].filter(Boolean),
  };
}

async function searchNaverLocal(query, limit = 5) {
  const data = await requestJson(`${apiBase}/api/naver/local?query=${encode(query)}&display=${limit}`);
  return (data.items || [])
    .map(mapNaverItem)
    .filter((place) => Number.isFinite(place.lat) && Number.isFinite(place.lng));
}

function requestJson(url) {
  if (typeof window.fetch === "function") {
    return window.fetch(url).then((response) => {
      if (!response.ok) {
        throw new Error(`Request returned ${response.status}`);
      }
      return response.json();
    });
  }

  return new Promise((resolve, reject) => {
    const request = new XMLHttpRequest();
    request.open("GET", url, true);
    request.onload = () => {
      if (request.status < 200 || request.status >= 300) {
        reject(new Error(`Request returned ${request.status}`));
        return;
      }

      try {
        resolve(JSON.parse(request.responseText));
      } catch (error) {
        reject(error);
      }
    };
    request.onerror = () => reject(new Error("Network request failed"));
    request.send();
  });
}

async function resolvePlaces(query, limit = 5) {
  const knownMatches = searchPlaces(query, limit);

  if (shouldPreferKnownTransitPlace(query) && knownMatches.length) {
    return {
      places: knownMatches,
      queries: expandQuery(query),
      live: false,
    };
  }

  try {
    const liveResult = await searchNaverLocalExpanded(query, limit);
    if (liveResult.places.length) {
      return {
        places: liveResult.places,
        queries: liveResult.queries,
        corrections: liveResult.corrections || [],
        live: true,
      };
    }
  } catch {
    // Fall back to bundled sample data when the local API server is not available.
  }

  return {
    places: knownMatches,
    queries: expandQuery(query),
    corrections: correctQuery(query).corrections,
    live: false,
  };
}

async function searchNaverLocalExpanded(query, limit = 5) {
  const intent = parseSearchIntent(query);
  const seenQueries = buildSearchQueries(intent, 8);
  const seenPlaces = new Set();
  const results = [];

  for (const [queryIndex, candidateQuery] of seenQueries.entries()) {
    let places = [];
    try {
      places = await searchNaverLocal(candidateQuery, Math.min(limit, 3));
    } catch {
      continue;
    }

    places.forEach((place) => {
      const key = `${place.koreanName}-${place.lat}-${place.lng}`;
      if (!seenPlaces.has(key)) {
        seenPlaces.add(key);
        results.push({
          ...place,
          matchScore: scoreNaverPlace(place, intent, queryIndex),
          sourceQuery: candidateQuery,
        });
      }
    });
  }

  return {
    places: results.sort((a, b) => b.matchScore - a.matchScore).slice(0, limit),
    queries: seenQueries,
    corrections: intent.corrections,
  };
}

function scoreNaverPlace(place, intent, queryIndex) {
  const text = `${place.koreanName} ${place.category} ${place.area}`;
  let score = 100 - queryIndex * 8;

  intent.specificCategories.forEach((term) => {
    if (text.includes(term)) score += 35;
  });

  intent.areas.forEach((area) => {
    if (text.includes(area.replace("역", ""))) score += 24;
  });

  if (intent.specificCategories.length && /카페|커피|고기|삼겹살|한우|치킨|감자탕/.test(text)) {
    const categoryText = intent.specificCategories.join(" ");
    if (!categoryText.includes("카페") && text.includes("카페")) score -= 30;
    if (!categoryText.includes("고기") && !categoryText.includes("삼겹살") && /고기|삼겹살|한우/.test(text)) score -= 20;
  }

  return score;
}

function routeLink(start, destination, mode) {
  const action = mode === "walk" ? "walk" : mode === "car" ? "car" : "public";
  const params = new URLSearchParams({
    slat: start.lat,
    slng: start.lng,
    sname: start.koreanName,
    dlat: destination.lat,
    dlng: destination.lng,
    dname: destination.koreanName,
    appname: appName,
  });

  return `nmap://route/${action}?${params.toString()}`;
}

function androidIntentLink(nmapUrl) {
  const withoutScheme = nmapUrl.replace("nmap://", "");
  return `intent://${withoutScheme}#Intent;scheme=nmap;action=android.intent.action.VIEW;category=android.intent.category.BROWSABLE;package=com.nhn.android.nmap;end`;
}

function placeLink(place) {
  const params = new URLSearchParams({
    lat: place.lat,
    lng: place.lng,
    name: place.koreanName,
    appname: appName,
  });

  return `nmap://place?${params.toString()}`;
}

function naverWebSearchLink(place) {
  return `https://map.naver.com/p/search/${encode(place.koreanName)}`;
}

function naverWebRouteLink(start, destination) {
  return `https://map.naver.com/p/directions/${start.lng},${start.lat},${encode(start.koreanName)},PLACE_POI/${destination.lng},${destination.lat},${encode(destination.koreanName)},PLACE_POI/-/transit`;
}

function currentNaverUrl(nmapUrl) {
  return /Android/i.test(navigator.userAgent) ? androidIntentLink(nmapUrl) : nmapUrl;
}

function gradeClass(grade) {
  if (grade === "A") return "grade-a";
  if (grade === "B") return "grade-b";
  if (grade === "C") return "grade-c";
  if (grade === "D") return "grade-d";
  return "";
}

function gradeLabel(grade) {
  const labels = {
    A: "Easy waitlist",
    B: "Possible",
    C: "Hard",
    D: "Not tourist-friendly",
    Unknown: "Waitlist unknown",
  };
  return labels[grade] || labels.Unknown;
}

function isMobileBrowser() {
  return /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
}

function openNaver(url, fallbackUrl) {
  if (!isMobileBrowser()) {
    window.location.href = fallbackUrl;
    return;
  }

  window.location.href = currentNaverUrl(url);

  window.setTimeout(() => {
    showToast("If the app did not open, use Web Map.");
  }, 900);
}

function placeCard(place, options = {}) {
  const reviews = place.reviews ? `${place.reviews.toLocaleString()} reviews` : "Local place";
  const rating = place.rating ? `${place.rating.toFixed(1)} rating` : place.area;
  const canOpenNaverApp = Number.isFinite(place.lat) && Number.isFinite(place.lng);
  const openUrl = options.routeFrom && canOpenNaverApp ? routeLink(options.routeFrom, place, activeMode) : placeLink(place);
  const webUrl = options.routeFrom && canOpenNaverApp ? naverWebRouteLink(options.routeFrom, place) : naverWebSearchLink(place);

  const article = document.createElement("article");
  article.className = "result-card";
  article.innerHTML = `
    <div class="result-top">
      <div>
        <h3>${place.englishName}</h3>
        <p class="korean-name">${place.koreanName}</p>
      </div>
      <span class="pill ${gradeClass(place.waitlistGrade)}">${gradeLabel(place.waitlistGrade)}</span>
    </div>
    <div class="meta-row">
      <span class="pill">${place.category}</span>
      <span class="pill">${place.area}</span>
      <span class="pill">${rating}</span>
      <span class="pill">${reviews}</span>
    </div>
    <div class="card-actions">
      <button class="open-link" type="button"${canOpenNaverApp ? "" : " disabled"}>Open App</button>
      <button class="web-link" type="button">Web Map</button>
      ${options.allowGoHere ? '<button class="route-link" type="button">Go here</button>' : ""}
      <button class="save-link" type="button">Save</button>
    </div>
  `;

  article.querySelector(".open-link").addEventListener("click", () => openNaver(openUrl, webUrl));
  article.querySelector(".web-link").addEventListener("click", () => {
    window.location.href = webUrl;
  });
  article.querySelector(".route-link")?.addEventListener("click", () => {
    $("#toInput").value = place.koreanName;
    routePreferenceQuery = place.sourceQuery || place.koreanName;
    switchTab("go");
    renderRouteResults();
  });
  article.querySelector(".save-link").addEventListener("click", () => savePlace(place));

  return article;
}

function inferAreaQuery(place) {
  const source = `${place.koreanName} ${place.area}`;
  const knownAreas = ["성수", "성수동", "홍대", "홍대입구", "명동", "강남", "이태원", "연남", "합정", "잠실", "을지로", "종로"];
  return knownAreas.find((area) => source.includes(area)) || place.koreanName;
}

async function renderRouteResults() {
  const requestId = ++routeRequestId;
  const fromQuery = $("#fromInput").value;
  const toQuery = $("#toInput").value;
  const container = $("#routeResults");
  container.innerHTML = "";

  if (!fromQuery || !toQuery) {
    container.append(hint("Add both a starting point and destination."));
    return;
  }

  container.append(hint("Finding live NAVER map matches..."));

  const [startResult, destinationResult] = await Promise.all([
    resolvePlaces(fromQuery, 3),
    resolvePlaces(toQuery, 3),
  ]);

  if (requestId !== routeRequestId) return;

  const startMatches = startResult.places;
  const destinationMatches = destinationResult.places;
  container.innerHTML = "";

  if (!startMatches.length || !destinationMatches.length) {
    container.append(hint("No confident NAVER match yet. Try adding the area, like Hongdae, Seongsu, or Myeongdong."));
    return;
  }

  const start = startMatches[0];
  const destination = destinationMatches[0];
  container.append(hint(`Route matched with NAVER: ${start.koreanName} → ${destination.koreanName}`));
  const destinationIntent = parseSearchIntent(routePreferenceQuery || toQuery);
  if (destinationIntent.corrections.length) {
    container.append(hint(`Corrected likely typo: ${destinationIntent.corrections.join(", ")}. Searching with the corrected term.`));
  }
  destinationMatches.forEach((place) => container.append(placeCard(place, { routeFrom: start })));

  const areaQuery = destinationIntent.areas[0] || inferAreaQuery(destination);
  const destinationCategory = destinationIntent.specificCategories[0];
  const recommendationQuery = destinationCategory ? `${areaQuery} ${destinationCategory}` : `${areaQuery} 맛집`;
  const recommendationResult = await resolvePlaces(recommendationQuery, 5);

  if (requestId !== routeRequestId) return;

  if (recommendationResult.places.length) {
    container.append(hint(`Recommended near ${areaQuery} from NAVER: ${recommendationQuery}`));
    recommendationResult.places.forEach((place) => container.append(placeCard(place)));
  }
}

async function renderFindResults() {
  const requestId = ++findRequestId;
  const query = $("#findInput").value;
  const container = $("#findResults");
  container.innerHTML = "";

  if (!query) {
    container.append(hint("Search for a restaurant, station exit, cafe, market, or landmark."));
    return;
  }

  container.append(hint("Finding the Korean place name..."));

  const result = await resolvePlaces(query, 5);

  if (requestId !== findRequestId) return;

  let matches = result.places;
  const liveQueries = result.queries;
  const corrections = result.corrections || [];
  liveSearchAvailable = result.live;
  $("#apiNote").textContent = liveSearchAvailable
    ? "Live NAVER local search is connected."
    : "Using sample fallback. Start the local server for live NAVER Search.";

  container.innerHTML = "";

  if (!matches.length) {
    matches = searchPlaces(query, 5);
    if (!matches.length) {
      container.append(hint("No local match yet. Try adding the area, like Hongdae, Seongsu, or Myeongdong."));
      return;
    }
  }

  const expansions = expandQuery(query).slice(0, 4).join(" · ");
  const liveCopy = liveQueries.length ? `Live NAVER results using: ${liveQueries.slice(0, 3).join(" · ")}` : "Live NAVER local results";
  if (corrections.length) {
    container.append(hint(`Corrected likely typo: ${corrections.join(", ")}. Searching with the corrected term.`));
  }
  container.append(hint(liveSearchAvailable ? liveCopy : `Korean search ideas: ${expansions}`));
  matches.forEach((place) => container.append(placeCard(place, { allowGoHere: true })));
}

function debounce(callback, delay = 650) {
  let timeoutId;
  return (...args) => {
    window.clearTimeout(timeoutId);
    timeoutId = window.setTimeout(() => callback(...args), delay);
  };
}

function bindSearchInput(input, callback) {
  const debounced = debounce(callback);
  const runSoon = () => {
    debounced();
  };

  input.addEventListener("input", runSoon);
  input.addEventListener("change", callback);
  input.addEventListener("search", callback);
  input.addEventListener("keyup", runSoon);
}

function hint(text) {
  const p = document.createElement("p");
  p.className = "hint";
  p.textContent = text;
  return p;
}

function getSaved() {
  try {
    return JSON.parse(localStorage.getItem("bridge-seoul-saved") || "[]");
  } catch {
    return [];
  }
}

function setSaved(saved) {
  localStorage.setItem("bridge-seoul-saved", JSON.stringify(saved));
}

function savePlace(place) {
  const saved = getSaved();
  if (!saved.some((item) => item.id === place.id)) {
    saved.unshift(place);
    setSaved(saved);
  }
  renderSaved();
  showToast("Saved on this device");
}

function renderSaved() {
  const container = $("#savedResults");
  const saved = getSaved();
  container.innerHTML = "";

  if (!saved.length) {
    container.append(hint("Saved places will appear here. Try saving your hotel, airport, or a restaurant."));
    return;
  }

  saved.forEach((place) => container.append(placeCard(place)));
}

function showToast(message) {
  const toast = $("#toast");
  toast.textContent = message;
  toast.classList.add("is-visible");
  window.clearTimeout(showToast.timeoutId);
  showToast.timeoutId = window.setTimeout(() => toast.classList.remove("is-visible"), 2200);
}

function switchTab(tabName) {
  $$(".tab").forEach((tab) => tab.classList.toggle("is-active", tab.dataset.tab === tabName));
  $$(".panel").forEach((panel) => panel.classList.remove("is-active"));
  $(`#${tabName}Panel`).classList.add("is-active");
}

function init() {
  $$(".tab").forEach((tab) => {
    tab.addEventListener("click", () => switchTab(tab.dataset.tab));
  });

  $$(".mode").forEach((mode) => {
    mode.addEventListener("click", () => {
      activeMode = mode.dataset.mode;
      $$(".mode").forEach((item) => item.classList.toggle("is-active", item === mode));
      if ($("#goPanel").classList.contains("is-active") && $("#routeResults").children.length) {
        renderRouteResults();
      }
    });
  });

  $("#swapButton").addEventListener("click", () => {
    const from = $("#fromInput").value;
    $("#fromInput").value = $("#toInput").value;
    $("#toInput").value = from;
    renderRouteResults();
  });

  const routeInputHandler = () => {
    routePreferenceQuery = "";
    routeRequestId += 1;
    $("#routeResults").innerHTML = "";
    $("#routeResults").append(hint("Updating route with your latest input..."));
    renderRouteResults();
  };

  const findInputHandler = () => {
    findRequestId += 1;
    $("#findResults").innerHTML = "";
    $("#findResults").append(hint("Updating local search..."));
    renderFindResults();
  };

  bindSearchInput($("#fromInput"), routeInputHandler);
  bindSearchInput($("#toInput"), routeInputHandler);
  bindSearchInput($("#findInput"), findInputHandler);

  $("#buildRouteButton").addEventListener("click", renderRouteResults);
  $("#findButton").addEventListener("click", renderFindResults);
  $("#clearSavedButton").addEventListener("click", () => {
    setSaved([]);
    renderSaved();
    showToast("Saved places cleared");
  });
  $("#profileButton").addEventListener("click", () => {
    showToast("Sign-in can sync saved places later");
  });

  renderRouteResults();
  renderFindResults();
  renderSaved();
}

init();

# Deployment Guide

Bridge Seoul is a static frontend plus a small Python API proxy.

Important:

- Never put `NAVER_SEARCH_CLIENT_SECRET` in `index.html` or `app.js`.
- Browser code calls `/api/naver/local`.
- `server.py` calls NAVER Search API with server-side environment variables.
- Add your deployed site URL to NAVER Developers `WEB 설정`.

## Recommended Hosting

Use a Python web host such as Render, Railway, or Fly.io. Render is the simplest for this prototype.

## Render Setup

1. Push this folder to GitHub.
2. Create a new Render `Web Service`.
3. Connect the GitHub repo.
4. Use this start command:

```bash
python3 server.py
```

5. Add environment variables:

```text
HOST=0.0.0.0
NAVER_SEARCH_CLIENT_ID=your_client_id
NAVER_SEARCH_CLIENT_SECRET=your_client_secret
```

6. After deployment, copy the Render URL.

Example:

```text
https://bridge-seoul.onrender.com
```

7. In NAVER Developers, add that URL under `비로그인 오픈 API 서비스 환경 > WEB 설정`.

8. Test the deployed app:

```text
https://your-site.onrender.com/health
https://your-site.onrender.com
```

9. Test NAVER local search through the deployed backend:

```text
https://your-site.onrender.com/api/naver/local?query=강남%20초밥&display=2
```

## NAVER Developers Settings

For this prototype:

- Select API: `검색`
- Service environment: `WEB 설정`
- Local test URL: `http://127.0.0.1:8787`
- Production URL: your deployed site URL

Do not enable NAVER Login yet.

Do not check personal data permissions such as:

- 회원이름
- 연락처 이메일 주소
- 휴대전화번호
- 프로필 사진

## Sensitive User Data

The current prototype does not store personal data on the server.

Safe user-entered fields for now:

- Hotel/place name
- Start point
- Destination
- Saved places stored locally in the browser

If account sync is added later, the product will need:

- Privacy policy
- Data deletion flow
- Clear consent before cloud sync

## Important Before Public Sharing

The current NAVER Client Secret was pasted into chat during local setup. Before making the site public:

1. Go to NAVER Developers.
2. Open the app.
3. Click `재발급` for Client Secret.
4. Update the hosting provider environment variable.
5. Do not put the secret in frontend code.

