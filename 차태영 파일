<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>사진 정리 도우미</title>
  <style>
    :root {
      --ink: #191f28;
      --muted: #6b7684;
      --soft: #8b95a1;
      --line: #edf0f3;
      --paper: #f4f6f8;
      --panel: #ffffff;
      --blue: #3182f6;
      --blue-dark: #1b64da;
      --blue-soft: #e8f3ff;
      --red: #f04452;
      --red-soft: #fff0f2;
      --green: #00a881;
      --green-soft: #e7f8f3;
      --shadow: 0 18px 44px rgba(25, 31, 40, 0.08);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      background: var(--paper);
      color: var(--ink);
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
      letter-spacing: 0;
    }

    button, input, select {
      font: inherit;
    }

    button {
      border: 0;
      cursor: pointer;
    }

    .app {
      display: grid;
      grid-template-columns: 1fr;
      min-height: 100vh;
    }

    .sidebar {
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(244,246,248,0.88);
      color: var(--ink);
      padding: 16px 28px 8px;
      display: grid;
      grid-template-columns: minmax(220px, auto) minmax(0, 1fr);
      gap: 18px;
      align-items: center;
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(237,240,243,0.88);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 11px;
      min-height: 44px;
    }

    .brand-mark {
      width: 40px;
      height: 40px;
      border-radius: 14px;
      background: linear-gradient(135deg, #3182f6, #58c2ff);
      position: relative;
      box-shadow: 0 8px 20px rgba(49,130,246,0.28);
    }

    .brand-mark::after {
      content: "";
      position: absolute;
      left: 12px;
      top: 11px;
      width: 16px;
      height: 18px;
      border-radius: 7px;
      background: white;
      box-shadow: 8px -4px 0 rgba(255,255,255,0.55);
    }

    .brand strong {
      display: block;
      font-size: 16px;
      line-height: 1.2;
    }

    .brand span {
      display: block;
      color: var(--muted);
      font-size: 12px;
      margin-top: 2px;
    }

    .nav {
      display: flex;
      gap: 8px;
      justify-content: flex-end;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .nav button {
      height: 40px;
      border-radius: 999px;
      background: transparent;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 0 14px;
      text-align: left;
      white-space: nowrap;
    }

    .nav button.active,
    .nav button:hover {
      background: #ffffff;
      color: var(--ink);
      box-shadow: 0 8px 18px rgba(25,31,40,0.06);
    }

    .icon {
      width: 18px;
      height: 18px;
      display: inline-grid;
      place-items: center;
      color: currentColor;
      flex: 0 0 18px;
    }

    .privacy-card {
      display: none;
    }

    .privacy-card h2 {
      font-size: 14px;
      margin: 0 0 8px;
    }

    .privacy-card p {
      margin: 0;
      font-size: 12px;
      line-height: 1.55;
      color: #cbd8d3;
    }

    .main {
      width: min(1180px, calc(100% - 40px));
      margin: 0 auto;
      padding: 46px 0 36px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      min-width: 0;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .title h1 {
      margin: 0;
      max-width: 640px;
      font-size: clamp(34px, 5vw, 56px);
      line-height: 1.08;
      letter-spacing: 0;
      font-weight: 800;
    }

    .title p {
      margin: 14px 0 0;
      color: var(--muted);
      line-height: 1.55;
      font-size: 17px;
    }

    .actions {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .btn {
      min-height: 48px;
      border-radius: 14px;
      padding: 0 18px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--ink);
      background: #eef1f4;
      border: 1px solid transparent;
      white-space: nowrap;
      font-weight: 700;
    }

    .btn.primary {
      background: var(--blue);
      color: white;
      box-shadow: 0 10px 24px rgba(49,130,246,0.24);
    }

    .btn.primary:hover {
      background: var(--blue-dark);
    }

    .btn.warn {
      background: var(--red-soft);
      color: #d43645;
      border-color: #ffd9de;
    }

    .grid {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(340px, 0.8fr);
      gap: 18px;
      align-items: start;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 28px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .panel-head {
      padding: 17px 18px 12px;
      border-bottom: 1px solid var(--line);
      display: flex;
      justify-content: space-between;
      gap: 14px;
      align-items: flex-start;
    }

    .panel-head h2 {
      margin: 0;
      font-size: 22px;
      letter-spacing: 0;
    }

    .panel-head p {
      margin: 5px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .status-pill {
      border-radius: 999px;
      padding: 7px 11px;
      font-size: 12px;
      white-space: nowrap;
      background: var(--blue-soft);
      color: var(--blue);
      border: 1px solid #d7eaff;
      font-weight: 750;
    }

    .summary {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
      margin-top: 4px;
    }

    .metric {
      background: #ffffff;
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 22px;
      min-height: 126px;
      box-shadow: 0 10px 28px rgba(25,31,40,0.04);
    }

    .metric span {
      color: var(--muted);
      display: block;
      font-size: 12px;
      line-height: 1.3;
    }

    .metric strong {
      display: block;
      margin-top: 15px;
      font-size: 31px;
      line-height: 1;
    }

    .metric small {
      display: block;
      margin-top: 7px;
      color: var(--muted);
      font-size: 12px;
    }

    .album-list {
      display: grid;
      gap: 10px;
      padding: 18px;
    }

    .album-row {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr) auto;
      gap: 16px;
      align-items: center;
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 14px;
      background: #ffffff;
      cursor: pointer;
      transition: transform 160ms ease, box-shadow 160ms ease;
    }

    .album-row:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 30px rgba(25,31,40,0.07);
    }

    .thumbs {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 3px;
      width: 72px;
      height: 72px;
      overflow: hidden;
      border-radius: 18px;
      background: #edf2f7;
    }

    .photo {
      min-width: 0;
      min-height: 0;
      background-size: cover;
      background-position: center;
    }

    .p1 { background: linear-gradient(135deg, #b9e4ff, #3182f6 48%, #a3e7d8); }
    .p2 { background: linear-gradient(135deg, #eaf4ff, #72b8ff 50%, #c5d8ff); }
    .p3 { background: linear-gradient(135deg, #fff1c8, #ffb86b 46%, #ffd6e0); }
    .p4 { background: linear-gradient(135deg, #f2f4f6, #8b95a1 44%, #333d4b); }
    .p5 { background: linear-gradient(135deg, #ffe5ec, #ff7b9c 50%, #a36bff); }
    .p6 { background: linear-gradient(135deg, #dbfff3, #7ce7c7 50%, #92b5ff); }

    .album-title {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      min-width: 0;
    }

    .album-title input {
      border: 0;
      background: transparent;
      font-weight: 750;
      color: var(--ink);
      width: min(100%, 260px);
      min-height: 30px;
      padding: 0;
    }

    .tag {
      font-size: 11px;
      border-radius: 999px;
      padding: 5px 8px;
      background: #f2f4f6;
      color: var(--muted);
      border: 1px solid #eceff2;
      font-weight: 700;
    }

    .album-meta {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .row-actions {
      display: flex;
      gap: 7px;
      align-items: center;
    }

    .icon-btn {
      width: 34px;
      height: 34px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      background: #f2f4f6;
      color: var(--ink);
      border: 1px solid #edf0f3;
    }

    .icon-btn:hover {
      background: #e8f3ff;
      color: var(--blue);
    }

    .icon-btn.deny {
      background: var(--red-soft);
      color: #d43645;
      border-color: #ffd9de;
    }

    .settings {
      padding: 16px;
      display: grid;
      gap: 13px;
    }

    .setting {
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 18px;
      display: flex;
      gap: 12px;
      justify-content: space-between;
      align-items: center;
      background: #ffffff;
    }

    .setting strong {
      display: block;
      font-size: 14px;
    }

    .setting span {
      display: block;
      margin-top: 4px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.4;
    }

    .switch {
      width: 48px;
      height: 28px;
      border-radius: 999px;
      background: #ccd5d0;
      position: relative;
      flex: 0 0 auto;
    }

    .switch.on {
      background: var(--blue);
    }

    .switch::after {
      content: "";
      position: absolute;
      top: 4px;
      left: 4px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: white;
      box-shadow: 0 1px 4px rgba(0,0,0,0.22);
      transition: transform 160ms ease;
    }

    .switch.on::after {
      transform: translateX(20px);
    }

    .review-list {
      display: grid;
      gap: 12px;
      padding: 18px;
    }

    .review-group {
      border: 1px solid var(--line);
      border-radius: 24px;
      background: #fbfcfb;
      overflow: hidden;
      transition: transform 160ms ease, box-shadow 160ms ease;
    }

    .review-group:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 32px rgba(25,31,40,0.08);
    }

    .review-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 12px;
      border-bottom: 1px solid var(--line);
    }

    .review-top strong {
      font-size: 14px;
    }

    .review-top span {
      display: block;
      margin-top: 3px;
      color: var(--muted);
      font-size: 12px;
    }

    .strip {
      display: grid;
      grid-template-columns: repeat(5, minmax(54px, 1fr));
      gap: 8px;
      padding: 12px;
    }

    .candidate {
      aspect-ratio: 4 / 5;
      border-radius: 16px;
      position: relative;
      overflow: hidden;
      border: 2px solid transparent;
      background-size: cover;
      background-position: center;
    }

    .candidate.keep {
      border-color: var(--blue);
    }

    .candidate.delete {
      border-color: var(--red);
    }

    .review-reason {
      margin: 0 12px 12px;
      border-radius: 16px;
      background: #f3f7ff;
      color: #225ca3;
      padding: 11px 12px;
      font-size: 12px;
      line-height: 1.45;
    }

    .badge {
      position: absolute;
      left: 6px;
      bottom: 6px;
      max-width: calc(100% - 12px);
      border-radius: 6px;
      padding: 4px 6px;
      background: rgba(23,32,28,0.76);
      color: white;
      font-size: 10px;
      line-height: 1.2;
    }

    .review-actions {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      padding: 0 12px 12px;
    }

    .review-group {
      cursor: pointer;
    }

    .detail-backdrop {
      position: fixed;
      inset: 0;
      z-index: 30;
      background: rgba(25,31,40,0.42);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .detail-backdrop.open {
      display: flex;
    }

    .detail-sheet {
      width: min(1120px, 100%);
      max-height: min(840px, calc(100vh - 48px));
      background: #ffffff;
      border-radius: 28px;
      box-shadow: 0 24px 80px rgba(25,31,40,0.24);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .detail-head {
      padding: 22px 24px 16px;
      display: flex;
      justify-content: space-between;
      gap: 16px;
      border-bottom: 1px solid var(--line);
    }

    .detail-head h2 {
      margin: 0;
      font-size: 23px;
    }

    .detail-head p {
      margin: 6px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .detail-grid {
      padding: 18px;
      overflow: auto;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 14px;
    }

    .album-photo-grid {
      padding: 18px;
      overflow: auto;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
      gap: 12px;
    }

    .album-photo-card {
      border: 1px solid var(--line);
      border-radius: 18px;
      overflow: hidden;
      background: #f8fafb;
      text-align: left;
      cursor: zoom-in;
    }

    .album-photo-thumb {
      height: 172px;
      background-size: cover;
      background-position: center;
      background-color: #111820;
    }

    .album-photo-label {
      padding: 9px 10px;
      color: var(--muted);
      font-size: 12px;
    }

    .detail-photo {
      border: 2px solid transparent;
      border-radius: 20px;
      overflow: hidden;
      background: #f2f4f6;
      position: relative;
      min-height: 304px;
      text-align: left;
    }

    .detail-photo.selected {
      border-color: var(--red);
      box-shadow: 0 0 0 4px #fff0f2;
    }

    .detail-photo.protected {
      opacity: 0.62;
    }

    .detail-thumb {
      height: 220px;
      background-size: contain;
      background-position: center;
      background-repeat: no-repeat;
      background-color: #111820;
      cursor: zoom-in;
    }

    .detail-label {
      min-height: 78px;
      padding: 10px 11px;
      font-size: 12px;
      color: var(--muted);
      display: grid;
      gap: 7px;
    }

    .detail-label strong {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      color: var(--ink);
      font-size: 13px;
    }

    .detail-label p {
      margin: 0;
      color: #6b7684;
      line-height: 1.38;
    }

    .select-row {
      width: 100%;
      border: 0;
      background: transparent;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      text-align: left;
      font: inherit;
      color: inherit;
      cursor: pointer;
    }

    .select-row:disabled {
      cursor: not-allowed;
    }

    .check-dot {
      width: 20px;
      height: 20px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background: #e5e8eb;
      color: transparent;
      flex: 0 0 auto;
      font-size: 12px;
    }

    .detail-photo.selected .check-dot {
      background: var(--red);
      color: #ffffff;
    }

    .photo-viewer {
      position: fixed;
      inset: 0;
      z-index: 40;
      background: rgba(9,14,20,0.82);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 30px;
    }

    .photo-viewer.open {
      display: flex;
    }

    .photo-viewer-card {
      width: min(980px, 100%);
      max-height: calc(100vh - 60px);
      border-radius: 28px;
      background: #ffffff;
      overflow: hidden;
      display: grid;
      grid-template-rows: minmax(0, 1fr) auto;
      box-shadow: 0 30px 90px rgba(0,0,0,0.35);
    }

    .photo-viewer-image {
      min-height: 420px;
      background: #0d141b center / contain no-repeat;
    }

    .photo-viewer-info {
      padding: 16px 18px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .photo-viewer-info strong {
      display: block;
      font-size: 15px;
    }

    .photo-viewer-info p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .detail-actions {
      border-top: 1px solid var(--line);
      padding: 14px 18px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .detail-count {
      color: var(--muted);
      font-size: 13px;
    }

    .footer-band {
      border: 1px solid #d7eaff;
      background: linear-gradient(135deg, #e8f3ff, #ffffff);
      border-radius: 26px;
      padding: 18px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      color: #174b85;
    }

    .footer-band strong {
      display: block;
      font-size: 14px;
    }

    .footer-band span {
      display: block;
      margin-top: 3px;
      font-size: 12px;
      color: #4e7cab;
      line-height: 1.4;
    }

    .runtime-banner {
      border: 1px solid #d7eaff;
      background: linear-gradient(135deg, #ffffff, #e8f3ff);
      border-radius: 24px;
      padding: 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      box-shadow: 0 10px 28px rgba(49,130,246,0.08);
    }

    .runtime-banner strong {
      display: block;
      font-size: 16px;
    }

    .runtime-banner span {
      display: block;
      margin-top: 5px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .toast {
      position: fixed;
      right: 24px;
      bottom: 24px;
      background: #17201c;
      color: white;
      padding: 12px 14px;
      border-radius: 14px;
      box-shadow: var(--shadow);
      opacity: 0;
      transform: translateY(10px);
      transition: 180ms ease;
      pointer-events: none;
      font-size: 13px;
    }

    .toast.show {
      opacity: 1;
      transform: translateY(0);
    }

    [data-view] { display: none; }
    [data-view].visible { display: block; }

    @media (max-width: 1020px) {
      .app {
        grid-template-columns: 1fr;
      }

      .sidebar {
        padding: 12px 16px 8px;
        gap: 12px;
        grid-template-columns: 1fr;
      }

      .nav {
        justify-content: flex-start;
      }

      .privacy-card {
        display: none;
      }

      .grid {
        grid-template-columns: 1fr;
      }

      .summary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 680px) {
      .main {
        width: min(100% - 28px, 680px);
        padding: 28px 0 24px;
      }

      .topbar,
      .runtime-banner,
      .footer-band,
      .detail-actions,
      .review-actions {
        align-items: stretch;
        flex-direction: column;
      }

      .actions {
        justify-content: stretch;
      }

      .btn {
        justify-content: center;
        width: 100%;
      }

      .nav {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .album-row {
        grid-template-columns: 72px minmax(0, 1fr);
      }

      .thumbs {
        width: 72px;
        height: 72px;
        grid-template-columns: repeat(2, 1fr);
      }

      .row-actions {
        grid-column: 1 / -1;
        justify-content: flex-end;
      }

      .summary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }

      .metric {
        min-height: 112px;
        padding: 17px;
      }

      .strip {
        grid-template-columns: repeat(3, minmax(58px, 1fr));
      }

      .detail-grid {
        grid-template-columns: 1fr;
      }

      .album-photo-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .detail-thumb {
        height: 260px;
      }

      .photo-viewer {
        padding: 14px;
      }

      .photo-viewer-image {
        min-height: 360px;
      }

      .photo-viewer-info {
        align-items: stretch;
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-mark" aria-hidden="true"></div>
        <div>
          <strong>사진 정리 도우미</strong>
          <span>Mac Photos 로컬 분석</span>
        </div>
      </div>

      <nav class="nav" aria-label="주요 화면">
        <button class="active" data-tab="dashboard" title="요약 화면">
