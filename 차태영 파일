  <script>
    let albums = [
      { name: "2025 제주 여행", type: "AI 발견", count: 428, meta: "위치와 날짜 기반으로 묶음", colors: ["p1", "p2", "p3"], approved: true },
      { name: "문서와 영수증", type: "기본", count: 311, meta: "스크린샷과 문서 사진 중심", colors: ["p4", "p6", "p2"], approved: true },
      { name: "카페 디저트", type: "AI 발견", count: 186, meta: "음식 카테고리에서 세분화", colors: ["p3", "p5", "p6"], approved: false },
      { name: "운동 기록 캡처", type: "AI 발견", count: 94, meta: "스크린샷과 날짜 패턴", colors: ["p4", "p2", "p1"], approved: true },
      { name: "밤과 야경", type: "기본", count: 152, meta: "저조도 풍경 사진", colors: ["p4", "p2", "p5"], approved: false },
      { name: "제품 비교 사진", type: "AI 발견", count: 73, meta: "비슷한 구도와 쇼핑 사진", colors: ["p6", "p3", "p4"], approved: true }
    ];

    let reviews = [
      { title: "강릉 바다 연사 사진", meta: "12장 중 3장 삭제 검토", reason: "흐림과 유사 구도", colors: ["p2", "p2", "p1", "p4", "p2"] },
      { title: "회의 자료 스크린샷", meta: "8장 중 5장 삭제 검토", reason: "중복 스크린샷", colors: ["p4", "p4", "p4", "p6", "p4"] },
      { title: "단체 사진 후보", meta: "6장 중 2장 삭제 검토", reason: "눈 감음 가능성", colors: ["p5", "p1", "p5", "p3", "p5"] },
      { title: "카페 메뉴 사진", meta: "9장 중 4장 삭제 검토", reason: "비슷한 구도", colors: ["p3", "p6", "p3", "p5", "p3"] }
    ];

    const icons = {
      approve: "✓",
      deny: "×",
      delete: "⌫",
      keep: "★",
      search: "⌕"
    };

    function showToast(message) {
      const toast = document.getElementById("toast");
      toast.textContent = message;
      toast.classList.add("show");
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => toast.classList.remove("show"), 2200);
    }

    function sendNative(action, payload = {}) {
      if (window.webkit?.messageHandlers?.photoApp) {
        window.webkit.messageHandlers.photoApp.postMessage({ action, ...payload });
      } else {
        showToast("Mac 앱에서 실행하면 사진 앱과 연결됩니다.");
      }
    }

    function renderAlbum(album) {
      const row = document.createElement("article");
      row.className = "album-row";
      const albumThumbs = album.thumbnails?.length
        ? album.thumbnails.slice(0, 6).map(src => `<div class="photo real-photo" style="background-image:url('${src}')"></div>`).join("")
        : `${album.colors.map(color => `<div class="photo ${color}"></div>`).join("")}${album.colors.map(color => `<div class="photo ${color}"></div>`).join("")}`;
      row.innerHTML = `
        <div class="thumbs" aria-hidden="true">
          ${albumThumbs}
        </div>
        <div>
          <div class="album-title">
            <input value="${album.name}" aria-label="앨범 이름" />
            <span class="tag">${album.type}</span>
          </div>
          <div class="album-meta">${album.count.toLocaleString()}장 · ${album.meta}</div>
        </div>
        <div class="row-actions">
          <button class="icon-btn approve" title="추천 앨범 승인">${icons.approve}</button>
          <button class="icon-btn deny" title="추천 앨범 거절">${icons.deny}</button>
        </div>
      `;
      row.querySelector(".approve").addEventListener("click", () => showToast("추천 앨범을 승인 목록에 넣었습니다."));
      row.querySelector(".approve").addEventListener("click", () => {
        if (album.id) sendNative("approveAlbum", { id: album.id });
      });
      row.querySelector(".deny").addEventListener("click", () => {
        row.remove();
        showToast("이 추천 앨범은 반영하지 않습니다.");
        updateAlbumMetric();
      });
      row.querySelector("input").addEventListener("click", event => event.stopPropagation());
      row.querySelectorAll("button").forEach(button => {
        button.addEventListener("click", event => event.stopPropagation());
      });
      row.addEventListener("click", () => openAlbumDetail(album));
      return row;
    }

    let activeAlbum = null;

    function openAlbumDetail(album) {
      activeAlbum = album;
      const photos = album.photos?.length
        ? album.photos
        : (album.thumbnails || []).map((thumbnail, index) => ({
            id: `${album.id || "album"}-${index}`,
            thumbnail,
            fullImage: thumbnail,
            label: "앨범 포함"
          }));

      document.getElementById("albumDetailTitle").textContent = album.name;
      document.getElementById("albumDetailSubtitle").textContent = `${album.count.toLocaleString()}장 · ${album.meta}`;
      document.getElementById("albumDetailCount").textContent = `${photos.length.toLocaleString()}장 미리보기`;
      document.getElementById("albumDetailGrid").innerHTML = photos.map(photo => `
        <button class="album-photo-card" data-id="${photo.id}">
          <div class="album-photo-thumb" style="background-image:url('${photo.thumbnail}')"></div>
          <div class="album-photo-label">${photo.label || "앨범 포함"}</div>
        </button>
      `).join("");

      document.querySelectorAll("#albumDetailGrid .album-photo-card").forEach(button => {
        button.addEventListener("click", () => {
          const photo = photos.find(item => item.id === button.dataset.id);
          if (photo) openPhotoViewer({
            fullImage: photo.fullImage || photo.thumbnail,
            thumbnail: photo.thumbnail,
            label: album.name,
            reason: `${photo.label || "앨범 포함"} · 이 추천 앨범에 들어갈 사진입니다.`
          });
        });
      });

      document.getElementById("albumDetail").classList.add("open");
      document.getElementById("albumDetail").setAttribute("aria-hidden", "false");
    }

    function closeAlbumDetail() {
      document.getElementById("albumDetail").classList.remove("open");
      document.getElementById("albumDetail").setAttribute("aria-hidden", "true");
      activeAlbum = null;
    }

    function renderReview(item) {
      const group = document.createElement("article");
      group.className = "review-group";
      const reviewImages = item.thumbnails?.length ? item.thumbnails.slice(0, 5) : [];
      const suggestedCount = (item.photos || []).filter(photo => photo.isSuggestedDeletion && !photo.isProtected).length || item.deleteCandidateIdentifiers?.length || 0;
      group.innerHTML = `
        <div class="review-top">
          <div>
            <strong>${item.title}</strong>
            <span>${item.meta} · 삭제 후보 ${suggestedCount}장</span>
          </div>
          <span class="tag">즐겨찾기 제외됨</span>
        </div>
        <div class="strip">
          ${(reviewImages.length ? reviewImages : item.colors).map((value, index) => `
            <div class="candidate ${index === 0 ? "keep" : index > 2 ? "delete" : ""} photo ${reviewImages.length ? "real-photo" : value}" ${reviewImages.length ? `style="background-image:url('${value}')"` : ""}>
              <span class="badge">${index === 0 ? "보존 추천" : index > 2 ? "삭제 검토" : "비교"}</span>
            </div>
          `).join("")}
        </div>
        <p class="review-reason">${item.reason || "비슷한 사진을 묶어 직접 비교할 수 있게 준비했습니다."}</p>
        <div class="review-actions">
          <button class="btn"><span class="icon">${icons.keep}</span>묶음 보존</button>
          <button class="btn warn"><span class="icon">${icons.search}</span>개별 사진 보기</button>
        </div>
      `;
      group.querySelector(".warn").addEventListener("click", () => showToast("실제 제품에서는 macOS 확인창을 한 번 더 표시합니다."));
      group.querySelector(".warn").addEventListener("click", () => {
        openReviewDetail(item);
      });
      group.querySelector(".btn").addEventListener("click", () => showToast("이 묶음은 삭제 제안에서 제외했습니다."));
      group.addEventListener("click", (event) => {
        if (event.target.closest("button")) return;
        openReviewDetail(item);
      });
      return group;
    }

    let activeReview = null;
    let selectedPhotoIds = new Set();

    function openReviewDetail(item) {
      activeReview = item;
      selectedPhotoIds = new Set((item.photos || [])
        .filter(photo => photo.isSuggestedDeletion && !photo.isProtected)
        .map(photo => photo.id));

      document.getElementById("detailTitle").textContent = item.title;
      document.getElementById("detailSubtitle").textContent = `${item.reason || item.meta} 사진을 눌러 크게 보고, 삭제할 사진만 선택하세요.`;
      renderDetailGrid();
      document.getElementById("reviewDetail").classList.add("open");
      document.getElementById("reviewDetail").setAttribute("aria-hidden", "false");
    }

    function closeReviewDetail() {
      document.getElementById("reviewDetail").classList.remove("open");
      document.getElementById("reviewDetail").setAttribute("aria-hidden", "true");
      activeReview = null;
      selectedPhotoIds = new Set();
    }

    function renderDetailGrid() {
      const grid = document.getElementById("detailGrid");
      const photos = activeReview?.photos || [];
      grid.innerHTML = photos.map(photo => {
        const selected = selectedPhotoIds.has(photo.id);
        return `
          <article class="detail-photo ${selected ? "selected" : ""} ${photo.isProtected ? "protected" : ""}" data-id="${photo.id}">
            <div class="detail-thumb" data-id="${photo.id}" style="background-image:url('${photo.fullImage || photo.thumbnail}')"></div>
            <div class="detail-label">
              <button class="select-row" data-id="${photo.id}" ${photo.isProtected ? "disabled" : ""}>
                <strong>
                  <span>${photo.label}</span>
                  <span class="check-dot">✓</span>
                </strong>
              </button>
            </div>
          </article>
        `;
      }).join("");

      grid.querySelectorAll(".detail-thumb").forEach(thumb => {
        thumb.addEventListener("click", () => {
          const photo = photos.find(item => item.id === thumb.dataset.id);
          if (photo) openPhotoViewer({
            ...photo,
            reason: activeReview?.reason || "묶음 기준을 확인한 뒤 삭제 여부를 판단해 주세요."
          });
        });
      });

      grid.querySelectorAll(".select-row").forEach(button => {
        button.addEventListener("click", () => {
          const id = button.dataset.id;
          if (selectedPhotoIds.has(id)) {
            selectedPhotoIds.delete(id);
          } else {
            selectedPhotoIds.add(id);
          }
          renderDetailGrid();
        });
      });

      document.getElementById("detailCount").textContent = `${selectedPhotoIds.size}장 선택됨`;
    }

    function openPhotoViewer(photo) {
      document.getElementById("viewerImage").style.backgroundImage = `url('${photo.fullImage || photo.thumbnail}')`;
      document.getElementById("viewerTitle").textContent = photo.label || "사진 보기";
      document.getElementById("viewerReason").textContent = photo.reason || "삭제 여부를 직접 판단해 주세요.";
      document.getElementById("photoViewer").classList.add("open");
      document.getElementById("photoViewer").setAttribute("aria-hidden", "false");
    }

    function closePhotoViewer() {
      document.getElementById("photoViewer").classList.remove("open");
      document.getElementById("photoViewer").setAttribute("aria-hidden", "true");
      document.getElementById("viewerImage").style.backgroundImage = "";
    }

    function updateAlbumMetric() {
      document.getElementById("albumMetric").textContent = document.querySelectorAll("#allAlbums .album-row").length;
    }

    function updateSummary(summary = {}) {
      document.getElementById("analyzedMetric").textContent = Number(summary.analyzedCount || 0).toLocaleString();
      document.getElementById("albumMetric").textContent = Number(summary.recommendedAlbumCount || albums.length).toLocaleString();
      document.getElementById("reviewMetric").textContent = Number(summary.reviewGroupCount || reviews.length).toLocaleString();
    }

    function setRuntimeStatus(mode, text) {
      document.getElementById("runtimeTitle").textContent = mode;
      document.getElementById("runtimeText").textContent = text;
    }

    function fill(containerId, items, renderer, limit) {
      const container = document.getElementById(containerId);
      container.innerHTML = "";
      items.slice(0, limit || items.length).forEach(item => container.appendChild(renderer(item)));
    }

    function showTab(name) {
      document.querySelectorAll("[data-view]").forEach(view => {
        view.classList.toggle("visible", view.dataset.view === name);
      });
      document.querySelectorAll(".nav button").forEach(button => {
        button.classList.toggle("active", button.dataset.tab === name);
      });
    }

    fill("dashboardAlbums", albums, renderAlbum, 3);
    fill("allAlbums", albums, renderAlbum);
    fill("dashboardReviews", reviews, renderReview, 2);
    fill("allReviews", reviews, renderReview);
    updateSummary({
      analyzedCount: 18420,
      recommendedAlbumCount: albums.length,
      reviewGroupCount: reviews.length
    });

    document.querySelectorAll(".nav button").forEach(button => {
      button.addEventListener("click", () => showTab(button.dataset.tab));
    });

    document.getElementById("openPrivacy").addEventListener("click", () => showTab("privacy"));
    document.getElementById("closeAlbumDetail").addEventListener("click", closeAlbumDetail);
    document.getElementById("albumDetail").addEventListener("click", (event) => {
      if (event.target.id === "albumDetail") closeAlbumDetail();
    });
    document.getElementById("approveAlbumFromDetail").addEventListener("click", () => {
      if (activeAlbum?.id) {
        sendNative("approveAlbum", { id: activeAlbum.id });
        closeAlbumDetail();
      }
    });
    document.getElementById("closeDetail").addEventListener("click", closeReviewDetail);
    document.getElementById("reviewDetail").addEventListener("click", (event) => {
      if (event.target.id === "reviewDetail") closeReviewDetail();
    });
    document.getElementById("closeViewer").addEventListener("click", closePhotoViewer);
    document.getElementById("photoViewer").addEventListener("click", (event) => {
      if (event.target.id === "photoViewer") closePhotoViewer();
    });
    document.getElementById("clearSelection").addEventListener("click", () => {
      selectedPhotoIds = new Set();
      renderDetailGrid();
    });
    document.getElementById("deleteSelected").addEventListener("click", () => {
      const ids = Array.from(selectedPhotoIds);
      if (!ids.length) {
        showToast("삭제할 사진을 선택해주세요.");
        return;
      }
      sendNative("deleteAssets", { ids });
      closeReviewDetail();
    });
    document.getElementById("simulateScan").addEventListener("click", () => {
      showToast("로컬 분석 결과를 다시 계산합니다.");
      sendNative("refresh");
    });
    document.getElementById("newAlbumRecommendations").addEventListener("click", () => {
      showToast("다른 관점으로 앨범 후보를 다시 찾고 있습니다.");
      sendNative("newAlbumRecommendations");
    });
    document.getElementById("requestAccess").addEventListener("click", () => sendNative("requestAccess"));
    document.getElementById("approveAll").addEventListener("click", () => showToast("승인된 앨범 추가와 선택 삭제만 반영합니다."));

    window.photoAppNativeUpdate = function(payload) {
      setRuntimeStatus("Mac 앱 연결됨", `사진 권한 상태: ${payload.authorization || "확인 중"} · ${payload.notice || "로컬 분석 준비 완료"}`);
      albums = payload.albums || [];
      reviews = payload.reviews || [];

      fill("dashboardAlbums", albums, renderAlbum, 3);
      fill("allAlbums", albums, renderAlbum);
      fill("dashboardReviews", reviews, renderReview, 2);
      fill("allReviews", reviews, renderReview);
      updateSummary(payload.summary || {});

      if (payload.notice) showToast(payload.notice);
    };

    window.photoAppToast = showToast;

    window.addEventListener("load", () => {
      if (window.webkit?.messageHandlers?.photoApp) {
        setRuntimeStatus("Mac 앱 연결 중", "사진 접근 권한을 요청하고 있습니다.");
      }
      sendNative("requestAccess");
    });
  </script>
